# ROGI Environment Configuration
# Copy this file to .env and fill in your values

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_PATH=rogi.db

# ---------------------------------------------------------------------------
# Ollama
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ---------------------------------------------------------------------------
# FastAPI
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ---------------------------------------------------------------------------
# Telegram
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ---------------------------------------------------------------------------
# Email – IMAP accounts (JSON array)
# Format: [{"label":"Gmail","host":"imap.gmail.com","port":993,"username":"you@gmail.com","password":"app_password","ssl":true}]
# ---------------------------------------------------------------------------
IMAP_ACCOUNTS=[]

# Gmail OAuth (optional – alternative to app password)
GMAIL_ACCOUNTS=[]

# Outlook / Exchange
OUTLOOK_ACCOUNTS=[]

# ---------------------------------------------------------------------------
# Open WebUI
# ---------------------------------------------------------------------------
OPEN_WEBUI_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# n8n
# ---------------------------------------------------------------------------
N8N_URL=http://localhost:5678
N8N_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Digest schedule (cron expression)
# Default: every day at 07:00
# ---------------------------------------------------------------------------
DIGEST_CRON=0 7 * * *

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
